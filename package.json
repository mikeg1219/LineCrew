{
  "name": "linecrew",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:web:quick": "npx tsc --noEmit && npm run build",
    "test:web:full": "npm run lint && npx tsc --noEmit && npm run verify:payment-prerequisites && npm run build",
    "test:mobile:android:quick": "npm run mobile:android:sync",
    "verify:booking-pipeline": "node scripts/verify-booking-pipeline.mjs",
    "verify:payment-prerequisites": "node scripts/verify-payment-prerequisites.mjs",
    "deploy:prod": "node scripts/deploy-production.mjs",
    "db:supabase:link": "npx supabase link --project-ref iphcvzsgakbsadoekbrj",
    "db:legal": "npx supabase db query -f supabase/legal-foundation-migration.sql --linked",
    "mobile:android:add": "npx cap add android",
    "mobile:android:sync": "npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "mobile:ios:add": "npx cap add ios",
    "mobile:ios:sync": "npx cap sync ios",
    "mobile:ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
