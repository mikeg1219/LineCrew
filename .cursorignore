# Dependencies (hundreds of thousands of files — not useful for AI context)
node_modules/

# Next.js build output (regenerated by npm run dev / npm run build)
.next/
out/

# Test / tooling output
coverage/
.turbo/

# Vercel local link metadata (not source)
.vercel/

# Supabase CLI temp
supabase/.temp/

# Capacitor / Android generated (can be large after builds)
android/app/build/
android/.gradle/
android/build/
android/captures/

# iOS if added later
ios/Pods/
ios/build/

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS junk
.DS_Store
Thumbs.db
